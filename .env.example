# Runtime environment: "development" or "production".
ENV=development

# HTTP listen port.
PORT=8080

# Postgres connection string (DSN).
DATABASE_URL=postgres://orderflow:orderflow@localhost:5432/orderflow?sslmode=disable

# HMAC secret used to sign JWTs. Must be at least 16 characters.
# CHANGE THIS to a long random value in production.
JWT_SECRET=dev-secret-change-me-0123456789

# JWT lifetime as a Go duration (e.g. 24h, 12h, 30m).
JWT_TTL=24h
